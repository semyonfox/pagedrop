SEOL_TOKEN=replace-with-a-long-random-token
SEOL_PUBLIC_BASE_URL=http://localhost:8788
SEOL_DEFAULT_EXPIRY=1d
SEOL_MAX_EXPIRY=7d
SEOL_MAX_UPLOAD_BYTES=10485760
SEOL_MAX_EXTRACTED_BYTES=52428800
SEOL_MAX_FILES=100
# Enable only when Seol is reached through a trusted Cloudflare Tunnel.
SEOL_TRUST_PROXY_HEADERS=false
SEOL_UPLOADS_PER_MINUTE=5
SEOL_MAX_CONCURRENT_UPLOADS=2
# Optional: enable the Compose tunnel profile after configuring a public
# hostname whose service URL is http://seol:8080.
TUNNEL_TOKEN=replace-with-a-cloudflare-tunnel-token
