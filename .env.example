PAGEDROP_TOKEN=replace-with-a-long-random-token
PAGEDROP_PUBLIC_BASE_URL=http://localhost:8788
PAGEDROP_DEFAULT_EXPIRY=1d
PAGEDROP_MAX_EXPIRY=7d
PAGEDROP_MAX_UPLOAD_BYTES=10485760
PAGEDROP_MAX_EXTRACTED_BYTES=52428800
PAGEDROP_MAX_FILES=500
PAGEDROP_UPLOADS_PER_MINUTE=5
# Enable only when PageDrop is reached through a trusted Cloudflare Tunnel.
PAGEDROP_TRUST_PROXY_HEADERS=true
# Optional: enable the Compose tunnel profile after configuring a public
# hostname whose service URL is http://pagedrop:8080.
TUNNEL_TOKEN=replace-with-a-cloudflare-tunnel-token
